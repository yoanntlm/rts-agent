# Append this block to /etc/caddy/Caddyfile on the VPS.
# Do NOT replace the existing Caddyfile — it has other sites.
#
#   cat /opt/rts-agent/deploy/Caddyfile.snippet >> /etc/caddy/Caddyfile
#   systemctl reload caddy

citybuilder.yoanntlm.com {
    encode gzip

    # Proxy the runner's read-only file API (sandbox file viewer).
    handle /api/code/* {
        reverse_proxy localhost:4000
    }

    # Static SPA: serve client/dist for everything else, fall back to index.html.
    handle {
        root * /opt/rts-agent/client/dist
        try_files {path} /index.html
        file_server
    }

    # Vite-fingerprinted bundles (hash in filename) — safe to cache forever.
    @hashed path_regexp ^/assets/.+-[A-Za-z0-9_-]{6,}\.(js|css|woff2?)$
    header @hashed Cache-Control "public, max-age=31536000, immutable"

    # Everything else (tiles, chars, html, JSON, …) — always revalidate via ETag.
    # Browser keeps the copy and only re-downloads if ETag changed (304 otherwise).
    @revalidate not path_regexp ^/assets/.+-[A-Za-z0-9_-]{6,}\.(js|css|woff2?)$
    header @revalidate Cache-Control "no-cache"

    log {
        output file /var/log/caddy/citybuilder.log
        format console
    }
}
