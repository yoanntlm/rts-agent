# Append this block to /etc/caddy/Caddyfile on the VPS.
# Do NOT replace the existing Caddyfile — it has other sites.
#
#   cat /opt/rts-agent/deploy/Caddyfile.snippet >> /etc/caddy/Caddyfile
#   systemctl reload caddy

citybuilder.yoanntlm.com {
    root * /opt/rts-agent/client/dist
    encode gzip
    try_files {path} /index.html
    file_server

    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"
    header /index.html Cache-Control "no-cache"

    log {
        output file /var/log/caddy/citybuilder.log
        format console
    }
}
