{
  "name": "rts-agent",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./client\" --filter \"./agent-runner\" dev",
    "dev:client": "pnpm --filter ./client dev",
    "dev:runner": "pnpm --filter ./agent-runner dev",
    "convex:dev": "convex dev",
    "build": "pnpm --filter ./client build",
    "assets:gen": "pnpm --filter ./assets-gen start",
    "assets:avatars": "pnpm --filter ./assets-gen avatars",
    "assets:trim-avatars": "pnpm --filter ./assets-gen trim-avatars",
    "assets:buildings": "pnpm --filter ./assets-gen buildings",
    "assets:animate-building": "pnpm --filter ./assets-gen animate-building"
  },
  "devDependencies": {
    "convex": "^1.38.0",
    "typescript": "^5.6.0"
  }
}
