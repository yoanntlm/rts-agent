# Convex deployment URL — same one the client uses (from `npx convex dev` output).
CONVEX_URL=

# Model API key — pi will use whichever provider has a key configured.
# At least one must be set for the runner to spawn real agents.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# H4: Daytona for sandboxed shell execution (currently runs on host).
# DAYTONA_API_KEY=
